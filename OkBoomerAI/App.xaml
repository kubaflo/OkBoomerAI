<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:converters="clr-namespace:OkBoomerAI.Converters"
             x:Class="OkBoomerAI.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Converters -->
            <converters:InvertBoolConverter x:Key="InvertBool" />
            <converters:IsNotEmptyConverter x:Key="IsNotEmpty" />
            <converters:QuizButtonTextConverter x:Key="QuizButtonText" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
