@inherits LayoutComponentBase

<div class="app-container">
    <main class="page">
        @Body
    </main>
    
    <nav class="tab-bar">
        <a href="/" class="tab-item @(IsActive("/") ? "active" : "")">
            <div class="tab-icon-wrap">
                <svg class="tab-svg" viewBox="0 0 24 24" fill="currentColor"><path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z"/></svg>
            </div>
            <span class="tab-label">HOME</span>
        </a>
        <a href="/dictionary" class="tab-item @(IsActive("/dictionary") ? "active" : "")">
            <div class="tab-icon-wrap">
                <svg class="tab-svg" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zM6 4h5v8l-2.5-1.5L6 12V4z"/></svg>
            </div>
            <span class="tab-label">LIBRARY</span>
        </a>
        <a href="/history" class="tab-item @(IsActive("/history") ? "active" : "")">
            <div class="tab-icon-wrap">
                <svg class="tab-svg" viewBox="0 0 24 24" fill="currentColor"><path d="M13 3a9 9 0 0 0-9 9H1l3.89 3.89.07.14L9 12H6c0-3.87 3.13-7 7-7s7 3.13 7 7-3.13 7-7 7c-1.93 0-3.68-.79-4.94-2.06l-1.42 1.42A8.954 8.954 0 0 0 13 21a9 9 0 0 0 0-18zm-1 5v5l4.28 2.54.72-1.21-3.5-2.08V8H12z"/></svg>
            </div>
            <span class="tab-label">HISTORY</span>
        </a>
        <a href="/settings" class="tab-item @(IsActive("/settings") ? "active" : "")">
            <div class="tab-icon-wrap">
                <svg class="tab-svg" viewBox="0 0 24 24" fill="currentColor"><path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58a.49.49 0 0 0 .12-.61l-1.92-3.32a.49.49 0 0 0-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54a.484.484 0 0 0-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96a.49.49 0 0 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.07.62-.07.94s.02.64.07.94l-2.03 1.58a.49.49 0 0 0-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6A3.6 3.6 0 1 1 12 8.4a3.6 3.6 0 0 1 0 7.2z"/></svg>
            </div>
            <span class="tab-label">SETTINGS</span>
        </a>
    </nav>
</div>

@code {
    [Inject] NavigationManager Nav { get; set; } = default!;
    
    private bool IsActive(string path) => 
        path == "/" ? Nav.Uri == Nav.BaseUri : Nav.Uri.Contains(path);
}
