@page "/dictionary"
@inject SlangDataService SlangData
@inject IChatService ChatService
@inject IEmbeddingService EmbeddingService

<div class="library-header-row">
    <div class="library-title-group">
        <h2 class="library-title">SLANG LIBRARY</h2>
        <p class="library-subtitle">Learn Gen-Z slang with the power of AI</p>
    </div>
</div>

<div class="library-search-container">
    <div class="library-search-pill">
        <span class="search-icon-left">💡</span>
        <input type="text" class="library-search-input" @bind="searchText" @bind:event="oninput"
               @onkeyup="HandleSearch" placeholder="Search slang meaning..." />
        <span class="search-icon-right">🔍</span>
    </div>
</div>

@if (isLoadingEmbeddings)
{
    <p class="library-subtitle" style="text-align: center;">🧠 Loading semantic search...</p>
}

@if (showExplanation && selectedEntry != null)
{
    <div class="library-explanation-overlay fade-in" @onclick="() => showExplanation = false">
        <div class="library-explanation-card" @onclick:stopPropagation="true">
            <div class="explanation-header">
                <button class="btn-close" @onclick="() => showExplanation = false">✕</button>
            </div>
            
            <h3 class="explanation-term">@selectedEntry.Term</h3>
            
            <div class="explanation-scroll-content">
                @if (explanation.Contains("...")) 
                {
                    <div class="loading-spinner">
                        <div class="dot-loader"><span></span><span></span><span></span></div>
                        <p>Consulting the Gen-Z Oracles...</p>
                    </div>
                }
                else
                {
                    <div class="explanation-body">
                        @((MarkupString)FormatExplanation(explanation))
                    </div>
                }
            </div>
        </div>
    </div>
}

<div class="library-list">
    @foreach (var entry in filteredEntries)
    {
        <div class="library-item @GetCategoryClass(entry.Category)" @onclick="() => ExplainTerm(entry)">
            <div class="library-item-content">
                <div class="library-item-top">
                    <span class="library-item-term">@entry.Term</span>
                    <span class="library-item-tag">@GetCategoryTag(entry.Category)</span>
                </div>
                <p class="library-item-def">@entry.Definition</p>
                <p class="library-item-example">"@entry.Example"</p>
            </div>
        </div>
    }
</div>

@code {
    private List<SlangEntry> allEntries = [];
    private List<SlangEntry> filteredEntries = [];
    private Dictionary<string, float[]> embeddings = [];
    private string searchText = "";
    private bool isLoadingEmbeddings;
    private bool showExplanation;
    private SlangEntry? selectedEntry;
    private string explanation = "";

    private string FormatExplanation(string text)
    {
        if (string.IsNullOrWhiteSpace(text)) return "";
        
        // Remove "Generating explanation... 🧠" if it's there
        text = text.Replace("Generating explanation... 🧠", "");

        // Convert bold markdown (**Text**) to HTML <strong>
        text = System.Text.RegularExpressions.Regex.Replace(text, @"\*\*(.*?)\*\*", "<strong>$1</strong>");

        // Convert markdown bullets (- Item) to list items
        text = System.Text.RegularExpressions.Regex.Replace(text, @"^- (.*)", "<li>$1</li>", System.Text.RegularExpressions.RegexOptions.Multiline);
        
        // Wrap lists if any exist
        if (text.Contains("<li>"))
        {
            text = "<ul>" + text + "</ul>";
            // Clean up </ul><ul> scenarios if multiple lists appear
            text = text.Replace("</ul><ul>", "");
            // Move stray <li>s into valid ul blocks if regex was too aggressive? Or just let browser handle it.
            // Better: Let's focus on structure.
        }

        // Convert double newlines to paragraphs
        var paragraphs = text.Split(new[] { "\n\n" }, StringSplitOptions.RemoveEmptyEntries);
        var formatted = string.Join("", paragraphs.Select(p => 
        {
            if (p.Contains("<li>")) return p; // Assume it's a list block
            return $"<p>{p.Trim()}</p>";
        }));

        // Handle single newlines within paragraphs
        formatted = formatted.Replace("\n", "<br/>");

        return formatted;
    }

    protected override async Task OnInitializedAsync()
    {
        allEntries = await SlangData.GetEntriesAsync();
        filteredEntries = allEntries;
        _ = Task.Run(PrecomputeEmbeddings);
    }

    private string GetCategoryTag(string category) => category?.ToLower() switch
    {
        "emphasis" => "EMPHASIS",
        "praise" => "PRAISE",
        "criticism" => "CRITICISM",
        "dating" => "DATING",
        "internet" => "INTERNET",
        "social" => "SOCIAL",
        "empowerment" => "POWER",
        "confrontation" => "FIGHT",
        "obsession" => "OBSESSION",
        "modifier" => "MODIFIER",
        "humor" => "HUMOR",
        "description" => "VIBE",
        "self" => "SELF",
        "emotion" => "MOOD",
        "fandom" => "STAN",
        "manipulation" => "TOXIC",
        "expression" => "EXPRESSION",
        "adjective" => "DESCRIPTIVE",
        "verb" => "ACTION",
        "noun" => "OBJECT",
        "greeting" => "GREETING",
        "insult" => "ROAST",
        "compliment" => "GLAZE",
        "reaction" => "REACTION",
        "phrase" => "PHRASE",
        "acronym" => "SHORT",
        _ => "SLANG"
    };

    private string GetCategoryClass(string category) => category?.ToLower() switch
    {
        "praise" or "compliment" => "cat-green",
        "criticism" or "insult" or "confrontation" => "cat-red",
        "dating" or "emotion" or "obsession" => "cat-pink",
        "internet" or "acronym" => "cat-blue",
        "humor" or "expression" or "reaction" => "cat-orange",
        "social" or "fandom" => "cat-purple",
        "manipulation" => "cat-dark",
        "empowerment" or "verb" => "cat-teal",
        _ => "cat-gold"
    };

    private async Task PrecomputeEmbeddings()
    {
        isLoadingEmbeddings = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            foreach (var entry in allEntries)
            {
                var emb = await EmbeddingService.GetEmbeddingAsync($"{entry.Term}: {entry.Definition}");
                embeddings[entry.Term] = emb;
            }
        }
        catch { }
        finally { isLoadingEmbeddings = false; await InvokeAsync(StateHasChanged); }
    }

    private async Task HandleSearch()
    {
        if (string.IsNullOrWhiteSpace(searchText)) { filteredEntries = allEntries; return; }
        if (embeddings.Count > 0)
        {
            try
            {
                var qEmb = await EmbeddingService.GetEmbeddingAsync(searchText);
                filteredEntries = allEntries
                    .Where(e => embeddings.ContainsKey(e.Term))
                    .Select(e => new { Entry = e, Score = EmbeddingService.CosineSimilarity(qEmb, embeddings[e.Term]) })
                    .OrderByDescending(x => x.Score).Take(15).Select(x => x.Entry).ToList();
            }
            catch { filteredEntries = allEntries.Where(e => e.Term.Contains(searchText, StringComparison.OrdinalIgnoreCase) || e.Definition.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList(); }
        }
        else
        {
            filteredEntries = allEntries.Where(e => e.Term.Contains(searchText, StringComparison.OrdinalIgnoreCase) || e.Definition.Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList();
        }
    }

    private async Task ExplainTerm(SlangEntry entry)
    {
        selectedEntry = entry; showExplanation = true;
        explanation = "Generating explanation... 🧠";
        try
        {
            explanation = await ChatService.GetResponseAsync(Prompts.SlangExplainer, $"Explain: \"{entry.Term}\" ({entry.Definition})");
        }
        catch (Exception ex) { explanation = $"Couldn't explain: {ex.Message}"; }
    }
}
