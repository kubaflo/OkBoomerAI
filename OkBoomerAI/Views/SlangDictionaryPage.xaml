<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OkBoomerAI.ViewModels"
             xmlns:models="clr-namespace:OkBoomerAI.Models"
             x:Class="OkBoomerAI.Views.SlangDictionaryPage"
             x:DataType="vm:SlangDictionaryViewModel"
             Title="Dictionary"
             BackgroundColor="{StaticResource PageBackground}">

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16" RowSpacing="12">

        <!-- Header -->
        <VerticalStackLayout Spacing="4">
            <Label Text="📚 Slang Dictionary" FontSize="28" FontAttributes="Bold"
                   TextColor="{StaticResource PrimaryText}" />
            <Label Text="Search by meaning using AI embeddings ✨"
                   FontSize="13" TextColor="{StaticResource SubtleText}" />
            <Label Text="🧠 Loading semantic search..."
                   FontSize="12" TextColor="{StaticResource AccentPurple}"
                   IsVisible="{Binding IsLoadingEmbeddings}" />
        </VerticalStackLayout>

        <!-- Search -->
        <Border Grid.Row="1" StrokeShape="RoundRectangle 16"
                BackgroundColor="{StaticResource CardBackground}"
                Stroke="{StaticResource CardBorder}"
                Padding="8,4">
            <Grid ColumnDefinitions="*,Auto">
                <SearchBar Text="{Binding SearchText}"
                           Placeholder="Search by meaning... (e.g., 'angry')"
                           PlaceholderColor="{StaticResource SubtleText}"
                           TextColor="{StaticResource PrimaryText}"
                           CancelButtonColor="{StaticResource NeonGreen}"
                           SearchCommand="{Binding SearchCommand}" />
                <Button Grid.Column="1" Text="🔍"
                        Command="{Binding SearchCommand}"
                        BackgroundColor="Transparent"
                        FontSize="20"
                        WidthRequest="44" />
            </Grid>
        </Border>

        <!-- Slang List -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding FilteredEntries}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:SlangEntry">
                    <Border StrokeShape="RoundRectangle 12"
                            BackgroundColor="{StaticResource CardBackground}"
                            Stroke="{StaticResource CardBorder}"
                            Padding="16"
                            Margin="0,4">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer
                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:SlangDictionaryViewModel}}, Path=ExplainTermCommand}"
                                CommandParameter="{Binding .}" />
                        </Border.GestureRecognizers>
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" RowSpacing="4">
                            <Label Text="{Binding Term}"
                                   FontSize="18" FontAttributes="Bold"
                                   TextColor="{StaticResource NeonGreen}" />
                            <Border Grid.Column="1"
                                    StrokeShape="RoundRectangle 8"
                                    BackgroundColor="{StaticResource AccentPurple}"
                                    Padding="8,2"
                                    VerticalOptions="Center">
                                <Label Text="{Binding Category}"
                                       FontSize="11" TextColor="White" />
                            </Border>
                            <Label Grid.Row="1" Grid.ColumnSpan="2"
                                   Text="{Binding Definition}"
                                   FontSize="14"
                                   TextColor="{StaticResource PrimaryText}" />
                            <Label Grid.Row="2" Grid.ColumnSpan="2"
                                   Text="{Binding Example, StringFormat='&quot;{0}&quot;'}"
                                   FontSize="13" FontAttributes="Italic"
                                   TextColor="{StaticResource SubtleText}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Explanation Overlay -->
        <Border Grid.RowSpan="4"
                StrokeShape="RoundRectangle 20"
                BackgroundColor="{StaticResource CardBackground}"
                Stroke="{StaticResource NeonGreen}"
                StrokeThickness="2"
                Padding="20"
                Margin="8"
                IsVisible="{Binding ShowExplanation}"
                VerticalOptions="Center">
            <VerticalStackLayout Spacing="12">
                <Grid ColumnDefinitions="*,Auto">
                    <Label Text="{Binding SelectedEntry.Term}"
                           FontSize="24" FontAttributes="Bold"
                           TextColor="{StaticResource NeonGreen}" />
                    <Button Grid.Column="1" Text="✕"
                            Command="{Binding CloseExplanationCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource SubtleText}"
                            FontSize="20" />
                </Grid>
                <ScrollView MaximumHeightRequest="400">
                    <Label Text="{Binding SelectedExplanation}"
                           FontSize="15"
                           TextColor="{StaticResource PrimaryText}" />
                </ScrollView>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
