<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:OkBoomerAI.ViewModels"
             x:Class="OkBoomerAI.Views.SlangDecoderPage"
             x:DataType="vm:SlangDecoderViewModel"
             Title="Slang Decoder"
             Shell.NavBarIsVisible="False">

    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="{StaticResource PageBackground}" Offset="0.0" />
            <GradientStop Color="{StaticResource DarkBg}" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <Grid>
        <ScrollView>
            <VerticalStackLayout Padding="20,0" Spacing="16">

                <!-- ═══════════ HEADER ═══════════ -->
                <Image Source="boomer_hero.png"
                       HeightRequest="200"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       Margin="0,24,0,0" />

                <Label Text="Running Gen-Z Jokes on Legacy Humans"
                       FontSize="13"
                       FontAttributes="Italic"
                       TextColor="{StaticResource SubtleText}"
                       HorizontalTextAlignment="Center"
                       Margin="0,-8,0,0" />

                <!-- ═══════════ INPUT SECTION ═══════════ -->
                <Border StrokeShape="RoundRectangle 16"
                        Stroke="{StaticResource CardBorder}"
                        BackgroundColor="{StaticResource CardBackground}"
                        Padding="16,4"
                        Margin="0,8,0,0">
                    <Entry Text="{Binding InputText}"
                           Placeholder="Enter meme or joke..."
                           PlaceholderColor="{StaticResource SubtleText}"
                           TextColor="{StaticResource PrimaryText}"
                           FontSize="16"
                           BackgroundColor="Transparent" />
                </Border>

                <!-- Slider: Young ↔ Full Boomer -->
                <Grid ColumnDefinitions="Auto,*,Auto" Margin="4,0">
                    <Label Text="Young"
                           FontSize="12"
                           TextColor="{StaticResource NeonGreen}"
                           VerticalOptions="Center" />
                    <Slider Grid.Column="1"
                            Minimum="0" Maximum="5"
                            Value="{Binding ConfusionLevel}"
                            MinimumTrackColor="{StaticResource NeonGreen}"
                            MaximumTrackColor="{StaticResource CardBorder}"
                            ThumbColor="{StaticResource NeonGreen}"
                            Margin="8,0" />
                    <Label Grid.Column="2"
                           Text="Full Boomer"
                           FontSize="12"
                           TextColor="{StaticResource HotPink}"
                           VerticalOptions="Center" />
                </Grid>

                <!-- ═══════════ ACTION BUTTONS ═══════════ -->
                <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                    <Button Text="🔍 Explain the Joke"
                            Command="{Binding ExplainCommand}"
                            FontSize="15"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource NeonGreen}"
                            TextColor="{StaticResource DarkBg}" />
                    <Button Grid.Column="1"
                            Text="🤔 Huh?"
                            Command="{Binding HuhCommand}"
                            FontSize="15"
                            FontAttributes="Bold"
                            HeightRequest="50"
                            CornerRadius="14"
                            BackgroundColor="{StaticResource CyberYellow}"
                            TextColor="{StaticResource DarkBg}" />
                </Grid>

                <!-- ═══════════ RESULT SECTION ═══════════ -->
                <VerticalStackLayout Spacing="14"
                                     IsVisible="{Binding HasResult}"
                                     Margin="0,8,0,0">

                    <!-- Category Badge -->
                    <Border StrokeShape="RoundRectangle 20"
                            BackgroundColor="{StaticResource ElectricBlue}"
                            Stroke="Transparent"
                            Padding="16,6"
                            HorizontalOptions="Start">
                        <Label Text="{Binding Category}"
                               FontSize="13"
                               FontAttributes="Bold"
                               TextColor="{StaticResource DarkBg}" />
                    </Border>

                    <!-- Confusion Stars -->
                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                        <Label Text="Boomer Confusion Level:"
                               FontSize="13"
                               TextColor="{StaticResource SubtleText}"
                               VerticalOptions="Center" />
                        <Label Text="{Binding ConfusionStars, StringFormat='{0}/5 ★'}"
                               FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource CyberYellow}"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Explanation Card -->
                    <Border StrokeShape="RoundRectangle 16"
                            Stroke="{StaticResource CardBorder}"
                            StrokeThickness="1"
                            BackgroundColor="{StaticResource CardBackground}"
                            Padding="18,16">
                        <Label Text="{Binding ExplanationText}"
                               FontSize="15"
                               TextColor="{StaticResource PrimaryText}"
                               LineBreakMode="WordWrap"
                               LineHeight="1.4" />
                    </Border>

                    <!-- Humor Note Badge -->
                    <Border StrokeShape="RoundRectangle 20"
                            BackgroundColor="{StaticResource AccentPurple}"
                            Stroke="Transparent"
                            Padding="16,8"
                            HorizontalOptions="Start">
                        <Label Text="{Binding HumorNote}"
                               FontSize="12"
                               FontAttributes="Italic"
                               TextColor="{StaticResource PrimaryText}" />
                    </Border>

                    <!-- Share & Reset Buttons -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,4,0,0">
                        <Button Text="📤 Share"
                                Command="{Binding ShareCommand}"
                                FontSize="14"
                                HeightRequest="46"
                                CornerRadius="14"
                                BackgroundColor="{StaticResource CardBackground}"
                                BorderColor="{StaticResource ElectricBlue}"
                                BorderWidth="1"
                                TextColor="{StaticResource ElectricBlue}" />
                        <Button Grid.Column="1"
                                Text="👴 OK Boomer"
                                Command="{Binding ResetCommand}"
                                FontSize="14"
                                HeightRequest="46"
                                CornerRadius="14"
                                BackgroundColor="{StaticResource HotPink}"
                                TextColor="{StaticResource PrimaryText}" />
                    </Grid>
                </VerticalStackLayout>

                <!-- ═══════════ BUSY INDICATOR ═══════════ -->
                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   Color="{StaticResource NeonGreen}"
                                   HeightRequest="40"
                                   HorizontalOptions="Center" />

                <!-- Bottom spacing -->
                <BoxView HeightRequest="24" Color="Transparent" />

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
